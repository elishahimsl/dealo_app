{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./mobile/*"]
    },
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom"],
    "target": "esnext",
    "checkJs": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": []
  },
  "include": ["mobile/**/*", "vite-plugins/**/*", "*.js", "*.jsx", "*.ts", "*.tsx"],
  "exclude": ["node_modules", "mobile/node_modules", "dist", "mobile/dist", ".expo"]
}