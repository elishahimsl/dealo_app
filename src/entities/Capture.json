{
  "name": "Capture",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Auto-generated or user-defined title"
    },
    "content_type": {
      "type": "string",
      "enum": [
        "homework",
        "notes",
        "diagram",
        "idea",
        "reminder",
        "project",
        "other"
      ],
      "default": "other",
      "description": "AI-detected content type"
    },
    "file_url": {
      "type": "string",
      "description": "URL of uploaded file/image"
    },
    "file_type": {
      "type": "string",
      "enum": [
        "image",
        "pdf",
        "document"
      ],
      "description": "Type of file uploaded"
    },
    "ai_summary": {
      "type": "string",
      "description": "AI-generated summary of content"
    },
    "extracted_text": {
      "type": "string",
      "description": "OCR extracted text from image/document"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "AI-extracted keywords and tags"
    },
    "has_due_date": {
      "type": "boolean",
      "default": false,
      "description": "Whether a due date was detected"
    },
    "due_date": {
      "type": "string",
      "format": "date",
      "description": "Extracted or set due date"
    },
    "folder_id": {
      "type": "string",
      "description": "ID of folder this capture belongs to"
    },
    "is_favorite": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "title",
    "content_type",
    "file_url"
  ]
}