{
  "name": "Folder",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Folder name"
    },
    "type": {
      "type": "string",
      "enum": [
        "smart",
        "manual"
      ],
      "default": "manual",
      "description": "Smart folders are auto-generated, manual are user-created"
    },
    "category": {
      "type": "string",
      "enum": [
        "homework",
        "notes",
        "ideas",
        "projects",
        "reminders",
        "custom"
      ],
      "default": "custom"
    },
    "color": {
      "type": "string",
      "description": "Folder color (hex code)",
      "default": "#0066FF"
    },
    "icon": {
      "type": "string",
      "description": "Icon name for folder",
      "default": "Folder"
    },
    "item_count": {
      "type": "number",
      "default": 0,
      "description": "Number of captures in folder"
    }
  },
  "required": [
    "name",
    "type"
  ]
}